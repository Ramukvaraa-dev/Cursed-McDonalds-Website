# Cursed McDonald's Authentication Server
# ⚠️ SECURITY WARNING: Never commit the real .env to git!
# Always use .env.example as template and create .env locally

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# SECURITY KEYS
# ============================================
# Change this to a random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-2026

# ============================================
# GOOGLE OAUTH
# ============================================
# Get from: https://console.cloud.google.com/
# Steps:
# 1. Create project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web app)
# 4. Add redirect URIs: http://localhost:5000, http://localhost:3000
# 5. Copy Client ID and Secret

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================
# MICROSOFT OAUTH
# ============================================
# Get from: https://portal.azure.com/
# Steps:
# 1. Go to App registrations
# 2. Click "New registration"
# 3. Add Web platform redirect URI
# 4. Generate Client Secret
# 5. Copy values below

MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
MICROSOFT_TENANT_ID=common

# ============================================
# API CONFIGURATION
# ============================================
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE
# ============================================
# Users are stored in users.json (auto-created)
# Change path if needed
USERS_FILE=./users.json

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
